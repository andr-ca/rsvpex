
# .env example for docker-compose
# App
NODE_ENV=production
PORT=3000
BASE_URL=https://rsvp.yourdomain.com
SESSION_SECRET=replace_me_with_long_random

# Database
DATABASE_URL=postgres://rsvp:change_me@db:5432/rsvp

# Redis
REDIS_URL=redis://redis:6379/0

# Turnstile (Cloudflare)
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SITE_KEY=your_site_key
CAPTCHA_SECRET_KEY=your_secret_key

# Email (Postmark or Sendgrid)
POSTMARK_API_TOKEN=
SENDGRID_API_KEY=

# Twilio (optional SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Defaults
DEFAULT_ENABLE_HEURISTIC_DUP_CHECK=false
DEFAULT_REMINDER_DAYS_BEFORE=7
